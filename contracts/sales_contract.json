{
  "description": "Data contract for sales records, including JSON schema and Great Expectations rules.",
  "schema": {
    "type": "object",
    "properties": {
      "id": {
        "description": "Unique identifier for the sale record.",
        "type": "integer"
      },
      "customer_id": {
        "description": "Identifier for the customer.",
        "type": "string"
      },
      "product": {
        "description": "Name of the product sold.",
        "type": "string"
      },
      "qty": {
        "description": "Quantity of the product sold.",
        "type": "integer",
        "minimum": 1
      },
      "price": {
        "description": "Price per unit of the product.",
        "type": "number",
        "exclusiveMinimum": 0
      },
      "order_date": {
        "description": "Timestamp of the order.",
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["id", "customer_id", "product", "qty", "price", "order_date"]
  },
  "great_expectations_rules": [
    {
      "expectation": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "id"
      }
    },
    {
      "expectation": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "customer_id"
      }
    },
    {
      "expectation": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "order_date"
      }
    },
    {
      "expectation": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "qty",
        "type_": "INTEGER"
      }
    },
    {
      "expectation": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "price",
        "min_value": 0.01,
        "max_value": 20000.00
      }
    },
    {
      "expectation": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "product",
        "value_set": ["Laptop", "Mouse", "Keyboard", "Monitor", "Webcam", "Docking Station", "Headset"]
      }
    }
  ]
}
