{
  "table": "clientes",
  "description": "Contrato de qualidade para a tabela de clientes na camada Bronze.",
  "fields": [
    {
      "name": "id", 
      "type": "integer",
      "unique": true
    },
    {
      "name": "nome", 
      "type": "string",
      "pii": true
    },
    {
      "name": "email", 
      "type": "string",
      "regex": "^[\\w\\.-]+@[\\w\\.-]+\\.\\w+$",
      "pii": true
    },
    {
      "name": "cpf",
      "type": "string",
      "regex": "^[0-9]{3}\\.?[0-9]{3}\\.?[0-9]{3}-?[0-9]{2}$",
      "pii": true,
      "unique": true
    },
    {
      "name": "telefone", 
      "type": "string",
      "regex": "^[\\d\\s\\+\\-\\(\\)]+$",
      "pii": true
    },
    {
      "name": "cidade", 
      "type": "string"
    },
    {
      "name": "estado", 
      "type": "string"
    },
    {
      "name": "data_cadastro", 
      "type": "date"
    },
    {
      "name": "status", 
      "type": "string",
      "in_set": ["Ativo", "Inativo", "Pendente"]
    }
  ]
}