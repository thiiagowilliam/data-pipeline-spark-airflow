# ============================================================
# Data Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# ── MinIO / S3 ──────────────────────────────────────────────
MINIO_URL=http://localhost:9000
MINIO_ENDPOINT=http://minio:9000          # inside Docker network
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=datalake

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=airflow
DB_USER=airflow
DB_PASSWORD=airflow

# ── Airflow ──────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=                # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Data Simulator ───────────────────────────────────────────
CLIENT_ROWS=550000
SALES_ROWS=700000
INTERVAL_SECONDS=300

# ── Validation ───────────────────────────────────────────────
CONTRACT_DIR=/opt/airflow/dags/contracts
